SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
FROM_EMAIL=


# JWT secret key
JWT_SECRET=

# Geocoding provider settings (OpenStreetMap Nominatim, no API key needed)
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_TIMEOUT_MS=4000
GEOCODING_LANGUAGE=en
GEOCODING_GEOCODE_LIMIT=1
GEOCODING_AUTOCOMPLETE_LIMIT=5
# Optional comma-separated ISO country codes to restrict results, e.g. np,in
GEOCODING_COUNTRY_CODES=
# Optional but recommended: identify your app for Nominatim usage policy
NOMINATIM_USER_AGENT=bluewhale-investment-backend/1.0 (contact@example.com)
