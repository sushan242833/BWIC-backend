# Required
JWT_SECRET=replace-with-a-long-random-secret

# Optional runtime
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Optional database overrides
# Defaults: host=localhost, port=5432, name=blue_whale_investment_db, user=mac
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blue_whale_investment_db
DB_USER=mac
DB_PASSWORD=
DB_LOGGING=true

# Optional auth/cookie deployment overrides
AUTH_TOKEN_TTL=7d
AUTH_COOKIE_SAME_SITE=lax
# In production behind HTTPS, this should usually be true.
AUTH_COOKIE_SECURE=false
# Leave blank unless you need a shared cookie across subdomains.
AUTH_COOKIE_DOMAIN=

# Optional upload storage override
UPLOAD_DIR=storage/uploads

# Optional email configuration
# Required in production because password reset, OTP verification, and notification emails depend on it.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
MAIL_FROM=
NOTIFY_EMAIL=

# Optional initial admin seed values
# Used only by `npm run auth:seed-admin` or `npm run auth:seed-admin:prod`.
INITIAL_ADMIN_FULL_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Optional infrastructure override for geocoding
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org

# Optional AI extraction configuration for recommendation brief understanding
OPENAI_API_KEY=
OPENAI_BASE_URL=
AI_QUERY_MODEL=
AI_QUERY_ENABLED=true
AI_QUERY_TIMEOUT_MS=6000
