# Email / SMTP settings
# Used when the backend needs to send emails such as contact notifications or alerts.
# Required only if email sending is enabled in the project.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
# Inbox that should receive app notifications.
NOTIFY_EMAIL=
# Address shown as the sender of outgoing emails.
FROM_EMAIL=



# Auth settings
# Required for JWT-based auth and secure cookie sessions.
JWT_SECRET=
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=bwic_auth
AUTH_COOKIE_SAME_SITE=lax
# In production behind HTTPS, this should usually be true.
AUTH_COOKIE_SECURE=false
# Leave blank unless you need a shared cookie across subdomains.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_MAX_AGE_DAYS=7
AUTH_COOKIE_REMEMBER_ME_DAYS=30
BCRYPT_SALT_ROUNDS=12
# Used to create the first admin account via migration or `npm run auth:seed-admin`
INITIAL_ADMIN_FULL_NAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Application runtime settings
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
# Frontend origin allowed to call this backend, commonly used for CORS.
FRONTEND_ORIGIN=http://localhost:3000





# Database connection settings, Required for connecting the backend to PostgreSQL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=blue_whale_investment_db
DB_USER=
DB_PASSWORD=
# Enable SQL query logging in development.
DB_LOGGING=true




# File upload settings
# Controls where uploaded files are stored and the upload size limit.
UPLOAD_DIR=src/public/uploads
MAX_FILE_SIZE_MB=5



# Geocoding provider settings (OpenStreetMap Nominatim, no API key needed)
GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
GEOCODING_TIMEOUT_MS=4000
GEOCODING_LANGUAGE=en
GEOCODING_GEOCODE_LIMIT=1
GEOCODING_AUTOCOMPLETE_LIMIT=5
# Optional comma-separated ISO country codes to restrict results, e.g. np,in
GEOCODING_COUNTRY_CODES=
# Optional but recommended: identify your app for Nominatim usage policy
NOMINATIM_USER_AGENT=bluewhale-investment-backend/1.0 (contact@example.com)
