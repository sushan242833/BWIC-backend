{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@models/*": ["models/*"],
      "@config/*": ["config/*"],
      "@constants/*": ["constants/*"],
      "@controller/*": ["controller/*"],
      "@routes/*": ["routes/*"],
      "@utils/*": ["utils/*"],
      "@dto/*": ["dto/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "ts-node": {
    "files": true
  },
  "include": ["src"]
}
